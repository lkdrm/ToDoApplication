{
  "compilerOptions": {
    "rootDir": "./Scripts",
    "outDir": "./wwwroot",
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "legacy",
    "lib": [ "DOM", "ESNext" ],
    "strict": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false
  },
  "include": [ "./Scripts/**/*" ],
  "exclude": [ "node_modules" ]
}